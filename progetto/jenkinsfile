pipeline {
    agent any

    environment {
        AWS_REGION = 'eu-central-1'
        PROJECT    = "corso-devops"
        PATH       = "${JENKINS_HOME}/bin:${env.PATH}"
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timestamps()
    }

    parameters {
        booleanParam(name: 'SKIP_TESTS', defaultValue: false, description: 'Salta i test?')
        choice(name: 'ENVIRONMENT', choices: ['dev', 'staging', 'prod'], description: 'Seleziona l\'ambiente di deploy')
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
                script {
                    env.GIT_SHORT_SHA = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
                    env.IMAGE_TAG     = "${BUILD_NUMBER}-${env.GIT_SHORT_SHA}"
                }
                sh '''
                    echo "=========================================="
                    echo "  OrderFlow CI Pipeline"
                    echo "=========================================="
                    echo "Build:       #${BUILD_NUMBER}"
                    echo "Branch:      ${GIT_BRANCH}"
                    echo "Commit:      $(git log --oneline -1)"
                    echo "Image Tag:   ${IMAGE_TAG}"
                    echo "=========================================="
                '''
                echo "Checkout completato"
            }
        }

        stage('Setup Tools') {
            steps {
                sh '''
                    echo "=== Installing required tools ==="
                    TOOLS_DIR="${JENKINS_HOME}/bin"
                    mkdir -p "${TOOLS_DIR}"
                    if ! command -v aws >/dev/null 2>&1; then
                        echo "Installing AWS CLI v2..."
                        curl -sL "https://awscli.amazonaws.com/awscli-exe-linux-aarch64.zip" -o "/tmp/awscliv2.zip"
                        unzip -qo /tmp/awscliv2.zip -d /tmp
                        /tmp/aws/install --install-dir "${TOOLS_DIR}/aws-cli" --bin-dir "${TOOLS_DIR}"
                        rm -rf /tmp/awscliv2.zip /tmp/aws
                    else
                        echo "PASS: AWS CLI already installed ($(aws --version))"
                    fi
                    echo "=== Tools ready ==="
                '''
            }
        }

        stage('Validation') {
            steps {
                sh '''
                    echo "=== Validating project structure ==="
                    ERRORS=0
                    for svc in order-service inventory-service notification-service; do
                        echo "--- Checking ${svc} ---"
                        if [ ! -d "${svc}" ]; then
                            echo "  FAIL: directory not found"
                            ERRORS=$((ERRORS + 1))
                            continue
                        fi
                        for f in Dockerfile requirements.txt main.py; do
                            if [ -f "${svc}/${f}" ]; then
                                echo "  ${f}: OK"
                            else
                                echo "  ${f}: MISSING"
                                ERRORS=$((ERRORS + 1))
                            fi
                        done
                    done
                    if [ ${ERRORS} -gt 0 ]; then
                        echo "Validation FAILED with ${ERRORS} errors"
                        exit 1
                    fi
                    echo "Validation PASSED"
                '''
            }
        }

        stage('Build Images') {
            parallel {
                stage('Build order-service') {
                    steps {
                        dir('order-service') {
                            sh 'docker build -t ${PROJECT}/order-service:${IMAGE_TAG} -t ${PROJECT}/order-service:latest .'
                        }
                    }
                }
                stage('Build inventory-service') {
                    steps {
                        dir('inventory-service') {
                            sh 'docker build -t ${PROJECT}/inventory-service:${IMAGE_TAG} -t ${PROJECT}/inventory-service:latest .'
                        }
                    }
                }
                stage('Build notification-service') {
                    steps {
                        dir('notification-service') {
                            sh 'docker build -t ${PROJECT}/notification-service:${IMAGE_TAG} -t ${PROJECT}/notification-service:latest .'
                        }
                    }
                }
            }
        }

        stage('Unit Tests') {
            when {
                expression { return !params.SKIP_TESTS }
            }
            parallel {
                stage('Test order-service') {
                    steps {
                        sh '''
                            echo "=== Testing order-service ==="
                            docker run --rm ${PROJECT}/order-service:latest \
                                python -m pytest tests/ -v --tb=short 2>/dev/null \
                                || echo "No tests yet"
                        '''
                    }
                }
                stage('Test inventory-service') {
                    steps {
                        sh '''
                            echo "=== Testing inventory-service ==="
                            docker run --rm ${PROJECT}/inventory-service:latest \
                                python -m pytest tests/ -v --tb=short 2>/dev/null \
                                || echo "No tests yet"
                        '''
                    }
                }
                stage('Test notification-service') {
                    steps {
                        sh '''
                            echo "=== Testing notification-service ==="
                            docker run --rm ${PROJECT}/notification-service:latest \
                                python -m pytest tests/ -v --tb=short 2>/dev/null \
                                || echo "No tests yet"
                        '''
                    }
                }
            }
        }

        stage('Push to ECR') {
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: 'aws-credentials',
                        usernameVariable: 'AWS_ACCESS_KEY_ID',
                        passwordVariable: 'AWS_SECRET_ACCESS_KEY'
                    ),
                    string(
                        credentialsId: 'ecr-registry-url',
                        variable: 'ECR_REGISTRY'
                    )
                ]) {
                    sh '''
                        echo "=== Authenticating with ECR ==="
                        aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${ECR_REGISTRY}
                        echo "=== Pushing images ==="
                        for svc in order-service inventory-service notification-service; do
                            echo "--- Pushing ${svc} ---"
                            docker tag ${PROJECT}/${svc}:${IMAGE_TAG} ${ECR_REGISTRY}/corso-devops-${svc}:${IMAGE_TAG}
                            docker tag ${PROJECT}/${svc}:latest ${ECR_REGISTRY}/corso-devops-${svc}:latest
                            docker push ${ECR_REGISTRY}/corso-devops-${svc}:${IMAGE_TAG}
                            docker push ${ECR_REGISTRY}/corso-devops-${svc}:latest
                            echo "${svc} pushed successfully"
                        done
                        echo "=== All images pushed to ECR ==="
                    '''
                }
            }
        }

        stage('Verify ECR') {
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: 'aws-credentials',
                        usernameVariable: 'AWS_ACCESS_KEY_ID',
                        passwordVariable: 'AWS_SECRET_ACCESS_KEY'
                    ),
                    string(credentialsId: 'ecr-registry-url', variable: 'ECR_REGISTRY')
                ]) {
                    sh '''
                        echo "=== Verifying images in ECR ==="
                        for svc in order-service inventory-service notification-service; do
                            MANIFEST=$(aws ecr batch-get-image \
                                --repository-name corso-devops-${svc} \
                                --image-ids imageTag=${IMAGE_TAG} \
                                --query 'images[0].imageManifest' \
                                --output text --region ${AWS_REGION} 2>/dev/null)
                            if [ -z "$MANIFEST" ] || [ "$MANIFEST" = "None" ]; then
                                echo "FAIL: corso-devops-${svc}:${IMAGE_TAG} not found in ECR"
                                exit 1
                            fi
                            echo "PASS: corso-devops-${svc}:${IMAGE_TAG} verified in ECR"
                        done
                        echo "=== ECR verification passed ==="
                    '''
                }
            }
        }
    }

    post {
        success {
            echo """
====================================
Pipeline SUCCESS - Build #${BUILD_NUMBER}
Commit: ${env.GIT_SHORT_SHA}
Tag: ${env.IMAGE_TAG}
====================================
"""
        }
        failure {
            echo """
====================================
Pipeline FAILED - Build #${BUILD_NUMBER}
Commit: ${env.GIT_SHORT_SHA}
====================================
"""
        }
        always {
            sh '''
                echo "=== Final Cleanup ==="
                for SVC in order inventory notification; do
                    docker rm -f "test-${SVC}-${BUILD_NUMBER}" 2>/dev/null || true
                done
                docker ps -aq --filter "name=orderflow" | xargs -r docker rm -f || true
                docker image prune -f --filter "until=2h" || true
                echo "Cleanup completed"
            '''
            cleanWs()
        }
    }
}
